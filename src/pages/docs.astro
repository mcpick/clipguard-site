---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Documentation - Clipboard Guard">
  <Header />

  <main>
    <!-- Header Section -->
    <section class="section">
      <div class="container text-center">
        <h1 class="page-title">Documentation</h1>
        <p class="page-subtitle text-secondary">
          Everything you need to know to get started with Clipboard Guard
        </p>
      </div>
    </section>

    <!-- Content -->
    <section class="section section-surface">
      <div class="container">
        <div class="docs-content">
          <!-- Getting Started -->
          <div class="card docs-card">
            <h2 class="docs-section-title docs-title-primary">
              <span class="docs-icon"><Icon name="rocket" size={22} /></span>
              Getting Started
            </h2>

            <h3 class="docs-heading">1. Download and Install</h3>
            <p class="text-secondary">
              Download the appropriate version for your platform from the <a href={`${base}download`} class="docs-link">download page</a>.
              Run the installer and follow the setup wizard.
            </p>

            <h3 class="docs-heading">2. Grant Permissions</h3>
            <div class="docs-callout">
              <p class="docs-callout-title">macOS Users:</p>
              <p class="docs-callout-text text-secondary">
                You'll need to grant Accessibility permissions for paste blocking to work.
                Go to System Preferences &rarr; Security & Privacy &rarr; Privacy &rarr; Accessibility and add Clipboard Guard.
              </p>
            </div>

            <h3 class="docs-heading">3. Configure Protection</h3>
            <p class="text-secondary">
              Once installed, Clipboard Guard will appear in your system tray (Windows/Linux) or menu bar (macOS).
              Click the icon to open settings and configure your protection rules.
            </p>

            <h3 class="docs-heading">4. You're Protected!</h3>
            <p class="text-secondary docs-last-p">
              Clipboard Guard now monitors all clipboard operations and will alert you when suspicious activity is detected.
            </p>
          </div>

          <!-- macOS Permissions -->
          <div class="card docs-card">
            <h2 class="docs-section-title docs-title-info">
              <span class="docs-icon"><Icon name="lock" size={22} /></span>
              macOS Permissions
            </h2>

            <p class="text-secondary">
              Clipboard Guard requires specific permissions on macOS to function properly:
            </p>

            <h3 class="docs-heading">Accessibility Permission (Required for Paste Blocking)</h3>
            <ol class="docs-list text-secondary">
              <li>Open System Preferences (or System Settings on macOS 13+)</li>
              <li>Navigate to Security & Privacy &rarr; Privacy &rarr; Accessibility</li>
              <li>Click the lock icon to make changes (enter your password)</li>
              <li>Click the "+" button and add Clipboard Guard</li>
              <li>Ensure the checkbox next to Clipboard Guard is checked</li>
            </ol>

            <div class="docs-warning">
              <p class="docs-callout-title">Important:</p>
              <p class="docs-callout-text text-secondary">
                Without Accessibility permission, Clipboard Guard can monitor clipboard activity and show notifications,
                but cannot block paste operations. The app will still provide valuable security alerts.
              </p>
            </div>

            <h3 class="docs-heading">How to Grant Permissions</h3>
            <p class="text-secondary docs-last-p">
              When you first run Clipboard Guard, macOS will automatically prompt you to grant necessary permissions.
              If you decline initially, you can always grant them later through System Preferences.
            </p>
          </div>

          <!-- Configuring Rules -->
          <div class="card docs-card">
            <h2 class="docs-section-title docs-title-accent">
              <span class="docs-icon"><Icon name="settings" size={22} /></span>
              Configuring Rules
            </h2>

            <p class="text-secondary">
              Clipboard Guard uses a rule-based system to determine when to show notifications or block paste operations.
              Each rule specifies a source app, destination app, and action.
            </p>

            <h3 class="docs-heading">Rule Components</h3>
            <div class="grid grid-3 docs-rule-components">
              <div class="docs-rule-box">
                <h4 class="docs-rule-box-title">From</h4>
                <p class="text-secondary docs-rule-box-desc">Source application</p>
              </div>
              <div class="docs-rule-box">
                <h4 class="docs-rule-box-title">To</h4>
                <p class="text-secondary docs-rule-box-desc">Destination application</p>
              </div>
              <div class="docs-rule-box">
                <h4 class="docs-rule-box-title">Action</h4>
                <p class="text-secondary docs-rule-box-desc">Notify or Block</p>
              </div>
            </div>

            <h3 class="docs-heading">Actions Explained</h3>
            <div class="docs-actions-grid">
              <div class="docs-action-card docs-action-info">
                <h4 class="docs-action-title docs-title-info">NOTIFY</h4>
                <p class="text-secondary docs-action-desc">
                  Shows a notification when the paste operation occurs, but allows it to proceed.
                </p>
              </div>
              <div class="docs-action-card docs-action-warn">
                <h4 class="docs-action-title docs-title-accent">BLOCK</h4>
                <p class="text-secondary docs-action-desc">
                  Prevents the paste operation and shows a confirmation dialog.
                </p>
              </div>
            </div>

            <h3 class="docs-heading">Wildcards</h3>
            <p class="text-secondary">
              Use "Any App" in the From or To field to create rules that apply broadly:
            </p>
            <ul class="docs-list text-secondary">
              <li><strong>"Any App" &rarr; "Terminal":</strong> Alert for any content being pasted into Terminal</li>
              <li><strong>"Chrome" &rarr; "Any App":</strong> Monitor all pastes from Chrome</li>
              <li><strong>"Any App" &rarr; "All Apps":</strong> Log all clipboard activity</li>
            </ul>
          </div>

          <!-- Examples -->
          <div class="card docs-card">
            <h2 class="docs-section-title docs-title-primary">
              <span class="docs-icon"><Icon name="lightbulb" size={22} /></span>
              Common Examples
            </h2>

            <h3 class="docs-heading">Block Browser &rarr; Terminal</h3>
            <div class="docs-example">
              <p class="docs-example-label">Recommended for developers</p>
              <p class="text-secondary docs-example-text">
                From: "Chrome" &rarr; To: "Terminal" &rarr; Action: "BLOCK"<br>
                From: "Safari" &rarr; To: "iTerm" &rarr; Action: "BLOCK"
              </p>
            </div>

            <h3 class="docs-heading">Monitor All Cross-App Pastes</h3>
            <div class="docs-example">
              <p class="docs-example-label">Good for general awareness</p>
              <p class="text-secondary docs-example-text">
                From: "Any App" &rarr; To: "All Apps" &rarr; Action: "NOTIFY"
              </p>
            </div>

            <h3 class="docs-heading">Protect Sensitive Apps</h3>
            <div class="docs-example">
              <p class="docs-example-label">For financial or admin tools</p>
              <p class="text-secondary docs-example-text">
                From: "Any App" &rarr; To: "Banking App" &rarr; Action: "NOTIFY"<br>
                From: "Browser" &rarr; To: "Database Tool" &rarr; Action: "BLOCK"
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Support -->
    <section class="section">
      <div class="container text-center">
        <div class="card docs-support-card">
          <h3 class="docs-heading">Need Help?</h3>
          <p class="text-secondary docs-support-text">
            Found a bug or need assistance? We're here to help.
          </p>
          <div class="docs-support-links">
            <a href="https://github.com/mcpick/clipguard/issues" target="_blank" class="btn btn-secondary">Report Issue</a>
            <a href="https://github.com/mcpick/clipguard/discussions" target="_blank" class="btn btn-secondary">Discussions</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .page-title {
    font-size: 40px;
    margin-bottom: 16px;
    font-weight: 700;
  }

  .page-subtitle {
    font-size: 16px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 40px;
  }

  .section-surface {
    background: var(--color-surface);
  }

  .docs-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .docs-card {
    margin-bottom: 32px;
  }

  .docs-card:last-child {
    margin-bottom: 0;
  }

  .docs-section-title {
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .docs-icon {
    display: flex;
  }

  .docs-title-primary {
    color: var(--color-primary);
  }

  .docs-title-info {
    color: var(--color-info);
  }

  .docs-title-accent {
    color: var(--color-accent);
  }

  .docs-heading {
    margin-bottom: 16px;
  }

  .docs-link {
    color: var(--color-primary);
    text-decoration: none;
  }

  .docs-callout {
    background: var(--color-surface-alt);
    padding: 16px;
    border-radius: var(--radius-md);
    margin-bottom: 16px;
  }

  .docs-callout-title {
    margin: 0;
    color: var(--color-text);
    font-weight: 500;
  }

  .docs-callout-text {
    margin: 8px 0 0 0;
    font-size: 14px;
  }

  .docs-warning {
    background: var(--color-warn-bg);
    border-left: 4px solid var(--color-accent);
    padding: 16px;
    border-radius: var(--radius-md);
    margin-bottom: 16px;
  }

  .docs-list {
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .docs-last-p {
    margin: 0;
  }

  .docs-rule-components {
    gap: 16px;
    margin-bottom: 24px;
  }

  .docs-rule-box {
    background: var(--color-info-bg);
    padding: 16px;
    border-radius: var(--radius-md);
    text-align: center;
  }

  .docs-rule-box-title {
    margin: 0 0 8px 0;
    color: var(--color-info);
  }

  .docs-rule-box-desc {
    margin: 0;
    font-size: 14px;
  }

  .docs-actions-grid {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .docs-action-card {
    flex: 1;
    min-width: 200px;
    padding: 16px;
    border-radius: var(--radius-md);
  }

  .docs-action-info {
    background: var(--color-info-bg);
    border-left: 4px solid var(--color-info);
  }

  .docs-action-warn {
    background: var(--color-warn-bg);
    border-left: 4px solid var(--color-accent);
  }

  .docs-action-title {
    margin: 0 0 8px 0;
  }

  .docs-action-desc {
    margin: 0;
    font-size: 14px;
  }

  .docs-example {
    background: var(--color-surface-alt);
    padding: 16px;
    border-radius: var(--radius-md);
    margin-bottom: 16px;
  }

  .docs-example-label {
    margin: 0 0 8px 0;
    font-weight: 500;
  }

  .docs-example-text {
    margin: 0;
    font-size: 14px;
  }

  .docs-support-card {
    max-width: 600px;
    margin: 0 auto;
    background: var(--color-info-bg);
    border-left: 4px solid var(--color-info);
  }

  .docs-support-text {
    margin-bottom: 20px;
  }

  .docs-support-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
