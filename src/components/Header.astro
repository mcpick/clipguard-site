---
const currentPath = Astro.url.pathname;
---

<header style="background: white; border-bottom: 1px solid rgba(0,0,0,0.05); position: sticky; top: 0; z-index: 100;">
  <div class="container">
    <nav style="display: flex; align-items: center; justify-content: space-between; height: 64px;">
      <div style="display: flex; align-items: center;">
        <a href="/" style="display: flex; align-items: center; text-decoration: none; color: #1d1d1f; font-weight: 600; font-size: 18px;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-right: 8px;">
            <rect x="3" y="4" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2" fill="none"/>
            <path d="M8 8h8M8 12h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Clipboard Guard
        </a>
      </div>
      
      <div style="display: flex; align-items: center; gap: 32px;">
        <a href="/" style={`text-decoration: none; color: ${currentPath === '/' ? '#34c759' : '#1d1d1f'}; font-weight: 500;`}>
          Home
        </a>
        <a href="/download" style={`text-decoration: none; color: ${currentPath === '/download' ? '#34c759' : '#1d1d1f'}; font-weight: 500;`}>
          Download
        </a>
        <a href="/docs" style={`text-decoration: none; color: ${currentPath === '/docs' ? '#34c759' : '#1d1d1f'}; font-weight: 500;`}>
          Docs
        </a>
        <a href="https://github.com/mcpick/clipguard" target="_blank" rel="noopener" style="text-decoration: none; color: #1d1d1f; font-weight: 500;">
          GitHub
        </a>
        <a href="/download" class="btn btn-primary" style="margin-left: 16px;">
          Download Free
        </a>
      </div>
    </nav>
  </div>
</header>