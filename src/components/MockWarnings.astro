---
---

<div class="mock-warnings">
  <div class="warnings-header">
    <h3 class="warnings-title">Recent Warnings</h3>
    <button class="clear-btn">Clear All</button>
  </div>

  <div class="warnings-list">
    <div class="warning-item warning-blocked">
      <div class="warning-content">
        <div class="warning-dot warning-dot-accent"></div>
        <div>
          <div class="warning-label">Chrome &rarr; Terminal</div>
          <div class="warning-detail">Blocked paste operation</div>
        </div>
      </div>
      <span class="warning-time">2:34 PM</span>
    </div>

    <div class="warning-item warning-info">
      <div class="warning-content">
        <div class="warning-dot warning-dot-info"></div>
        <div>
          <div class="warning-label">Safari &rarr; iTerm</div>
          <div class="warning-detail">Cross-app paste detected</div>
        </div>
      </div>
      <span class="warning-time">1:42 PM</span>
    </div>

    <div class="warning-item warning-info">
      <div class="warning-content">
        <div class="warning-dot warning-dot-info"></div>
        <div>
          <div class="warning-label">Slack &rarr; Terminal</div>
          <div class="warning-detail">Cross-app paste detected</div>
        </div>
      </div>
      <span class="warning-time">12:15 PM</span>
    </div>

    <div class="warning-item warning-blocked">
      <div class="warning-content">
        <div class="warning-dot warning-dot-accent"></div>
        <div>
          <div class="warning-label">Chrome &rarr; iTerm</div>
          <div class="warning-detail">Blocked paste operation</div>
        </div>
      </div>
      <span class="warning-time">11:58 AM</span>
    </div>
  </div>
</div>

<style>
  .mock-warnings {
    padding: 20px;
    background: var(--color-surface);
  }

  .warnings-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .warnings-title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
  }

  .clear-btn {
    padding: 6px 12px;
    background: var(--color-surface-alt);
    color: var(--color-text-secondary);
    border: none;
    border-radius: 6px;
    font-size: 12px;
    cursor: pointer;
  }

  .warning-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px;
    border-radius: var(--radius-md);
    margin-bottom: 8px;
  }

  .warning-item:last-child {
    margin-bottom: 0;
  }

  .warning-blocked {
    background: var(--color-warn-bg);
    border-left: 3px solid var(--color-accent);
  }

  .warning-info {
    background: var(--color-info-bg);
    border-left: 3px solid var(--color-info);
  }

  .warning-content {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .warning-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .warning-dot-accent {
    background: var(--color-accent);
  }

  .warning-dot-info {
    background: var(--color-info);
  }

  .warning-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text);
  }

  .warning-detail {
    font-size: 12px;
    color: var(--color-text-secondary);
  }

  .warning-time {
    font-size: 12px;
    color: var(--color-text-secondary);
  }
</style>
