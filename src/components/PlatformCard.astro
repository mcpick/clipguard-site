---
import Icon from './Icon.astro';

export interface Props {
  platform: string;
  icon: string;
  downloads: Array<{
    name: string;
    url: string;
    description: string;
  }>;
  recommended?: string;
}

const { platform, icon, downloads, recommended } = Astro.props;
---

<div class="card platform-card">
  <div class="platform-header">
    <div class="platform-icon-wrap">
      <Icon name={icon} size={24} />
    </div>
    <h3 class="platform-name">{platform}</h3>
  </div>

  <div class="platform-downloads">
    {downloads.map((download) => (
      <a
        href={download.url}
        class:list={["btn", download.name === recommended ? "btn-primary" : "btn-secondary", "download-btn"]}
        download
      >
        <div>
          <div class="download-name">{download.name}</div>
          <div class:list={["download-desc", { "download-desc-light": download.name === recommended }]}>
            {download.description}
          </div>
        </div>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7,10 12,15 17,10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
      </a>
    ))}
  </div>
</div>

<style>
  .platform-card {
    height: 100%;
  }

  .platform-header {
    display: flex;
    align-items: center;
    margin-bottom: 16px;
    gap: 12px;
  }

  .platform-icon-wrap {
    color: var(--color-text);
  }

  .platform-name {
    margin: 0;
    font-size: 20px;
    font-weight: 600;
  }

  .platform-downloads {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .download-btn {
    text-decoration: none;
    justify-content: space-between;
  }

  .download-name {
    font-weight: 500;
  }

  .download-desc {
    font-size: 12px;
    opacity: 0.8;
  }

  .download-desc-light {
    color: rgba(255, 255, 255, 0.9);
  }
</style>
