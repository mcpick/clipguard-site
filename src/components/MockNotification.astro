<div style="background: white; border-radius: 8px; padding: 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.2); border: 1px solid rgba(0,0,0,0.1); max-width: 380px; margin: 0 auto;">
  <div style="display: flex; align-items: flex-start; gap: 12px; margin-bottom: 12px;">
    <div style="width: 32px; height: 32px; background: #34c759; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
        <rect x="3" y="4" width="18" height="14" rx="2" stroke="white" stroke-width="2" fill="none"/>
        <path d="M8 8h8M8 12h6" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
    <div style="flex: 1;">
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
        <h4 style="margin: 0; font-size: 14px; font-weight: 600; color: #1d1d1f;">Clipboard Guard</h4>
        <span style="font-size: 12px; color: #86868b;">now</span>
      </div>
      <p style="margin: 0; font-size: 13px; color: #1d1d1f; line-height: 1.4;">
        Content copied from <strong>Google Chrome</strong> is being pasted into <strong>Terminal</strong>
      </p>
    </div>
  </div>
  
  <div style="display: flex; gap: 8px; justify-content: flex-end;">
    <button style="padding: 8px 16px; background: #f1f3f5; color: #1d1d1f; border: none; border-radius: 6px; font-size: 13px; cursor: pointer; font-weight: 500;">
      Block
    </button>
    <button style="padding: 8px 16px; background: #007aff; color: white; border: none; border-radius: 6px; font-size: 13px; cursor: pointer; font-weight: 500;">
      Allow
    </button>
  </div>
</div>