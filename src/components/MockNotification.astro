---
---

<div class="mock-notification">
  <div class="mock-notification-header">
    <div class="mock-notification-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
        <rect x="3" y="4" width="18" height="14" rx="2" stroke="white" stroke-width="2" fill="none"/>
        <path d="M8 8h8M8 12h6" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="mock-notification-body">
      <div class="mock-notification-title-row">
        <h4 class="mock-notification-title">Clipboard Guard</h4>
        <span class="mock-notification-time">now</span>
      </div>
      <p class="mock-notification-text">
        Content copied from <strong>Google Chrome</strong> is being pasted into <strong>Terminal</strong>
      </p>
    </div>
  </div>

  <div class="mock-notification-actions">
    <button class="mock-btn-block">Block</button>
    <button class="mock-btn-allow">Allow</button>
  </div>
</div>

<style>
  .mock-notification {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: 16px;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border);
    max-width: 380px;
    margin: 0 auto;
  }

  .mock-notification-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 12px;
  }

  .mock-notification-icon {
    width: 32px;
    height: 32px;
    background: var(--color-primary);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .mock-notification-body {
    flex: 1;
  }

  .mock-notification-title-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .mock-notification-title {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
  }

  .mock-notification-time {
    font-size: 12px;
    color: var(--color-text-secondary);
  }

  .mock-notification-text {
    margin: 0;
    font-size: 13px;
    color: var(--color-text);
    line-height: 1.4;
  }

  .mock-notification-actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }

  .mock-btn-block {
    padding: 8px 16px;
    background: var(--color-surface-alt);
    color: var(--color-text);
    border: none;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
    font-weight: 500;
  }

  .mock-btn-allow {
    padding: 8px 16px;
    background: var(--color-info);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 13px;
    cursor: pointer;
    font-weight: 500;
  }
</style>
